{
  "name": "openclaw-deal-hunter",
  "version": "1.0.0",
  "description": "OpenClaw plugin: price watches, safe scans, and heuristic deal signals",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts.map",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "audit:full": "env NPM_CONFIG_CACHE=/tmp/openclaw-deal-hunter-npm-cache npm audit",
    "audit:prod": "env NPM_CONFIG_CACHE=/tmp/openclaw-deal-hunter-npm-cache npm audit --omit=dev",
    "build": "rm -rf dist && tsc",
    "pack:check": "env NPM_CONFIG_CACHE=/tmp/openclaw-deal-hunter-npm-cache npm pack --dry-run",
    "publish:dry-run": "env NPM_CONFIG_CACHE=/tmp/openclaw-deal-hunter-npm-cache npm publish --dry-run",
    "release:verify": "./scripts/verify-pack-install.sh",
    "test": "env PATH=\"/usr/bin:/bin:$PATH\" ./node_modules/.bin/vitest run --configLoader runner",
    "test:diagnose": "./scripts/test-diagnose.sh",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run build",
    "version": "node ./scripts/sync-plugin-version.mjs"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "openclaw-deal-hunter",
      "localPath": ".",
      "defaultChoice": "npm"
    },
    "release": {
      "publishToNpm": true
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "undici": "^7.24.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openclaw": "2026.3.13",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.11",
    "fast-xml-parser": "^5.5.8",
    "@mariozechner/pi-ai": "^0.61.0",
    "@mariozechner/pi-agent-core": "^0.61.0",
    "@mariozechner/pi-coding-agent": "^0.61.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cognostra/deal-finder.git"
  },
  "bugs": {
    "url": "https://github.com/Cognostra/deal-finder/issues"
  },
  "homepage": "https://github.com/Cognostra/deal-finder#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "deals",
    "shopping",
    "price-tracking"
  ]
}
